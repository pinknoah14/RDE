# ──────────────────────────────────────────
# RDE 환경 변수 설정
# 이 파일을 복사하여 .env 로 저장한 뒤 값을 입력하세요.
# Windows: copy .env.example .env
# ──────────────────────────────────────────

# DB 파일 경로
# 기본값 사용 권장 (data/ 폴더 아래 자동 생성)
RDE_DB_PATH=data/replenish.db

# 서버 설정
HOST=0.0.0.0
PORT=8000

# 프론트엔드 URL (CORS 허용 주소)
# 로컬 개발: http://localhost:3000
# 프로덕션 예시: https://workspace-noah.com
# 여러 개일 경우 쉼표로 구분: http://localhost:3000,https://workspace-noah.com
FRONTEND_URL=http://localhost:3000

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 로그 파일 저장 여부 (true / false)
LOG_TO_FILE=true
LOG_FILE_PATH=logs/rde.log
